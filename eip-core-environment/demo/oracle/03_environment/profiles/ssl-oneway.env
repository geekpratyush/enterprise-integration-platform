# ORACLE SSL ONEWAY PROFILE
export EIP_ROUTE_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/oracle/04_routes"
export EIP_CERT_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/oracle/02_initialization/certs"

# 1. Named DataSource: eip (SSL 1-Way)
export QUARKUS_DATASOURCE_EIP_JDBC_URL="jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCPS)(HOST=127.0.0.1)(PORT=2484))(CONNECT_DATA=(SERVICE_NAME=FREEPDB1))(SECURITY=(SSL_SERVER_DN_MATCH=FALSE)))"
export QUARKUS_DATASOURCE_EIP_USERNAME=eip_user
export QUARKUS_DATASOURCE_EIP_PASSWORD=eip_password
export QUARKUS_DATASOURCE_EIP_DB_KIND=oracle

# Quarkus Runtime Liquibase (Named DataSource: eip)
export QUARKUS_LIQUIBASE_EIP_MIGRATE_AT_START=true
export QUARKUS_LIQUIBASE_EIP_ENABLED=true
export QUARKUS_LIQUIBASE_EIP_CHANGE_LOG="filesystem:/home/pratyush/software/eip-core-integration/eip-core-environment/demo/oracle/02_initialization/changelog/db.changelog-master.yaml"

# SSL Metadata (Application Tier Trust)
export QUARKUS_DATASOURCE_EIP_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStore=${EIP_CERT_DIR}/ssl-oneway/oracle-truststore.p12
export QUARKUS_DATASOURCE_EIP_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStorePassword=EipPass123!
export QUARKUS_DATASOURCE_EIP_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStoreType=PKCS12

# ============================================================
# Java 21 Security Override for Oracle TCPS
# ============================================================
# Java 21 disables ALL TLS_RSA_* cipher suites by default.
# Oracle's TCPS listener ONLY supports RSA key exchange.
# The java.security.properties override re-enables them.
# NOTE: JAVA_TOOL_OPTIONS is set in start-eip.sh AFTER PKI
#       generation to avoid breaking keytool.
# ============================================================
ORACLE_SECURITY_FILE="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/oracle/03_environment/java-oracle.security"
export JAVA_OPTS="-Djava.security.properties=${ORACLE_SECURITY_FILE} -Doracle.net.disableOob=true -Djava.security.egd=file:/dev/./urandom -Djavax.net.ssl.trustStore=${EIP_CERT_DIR}/ssl-oneway/oracle-truststore.p12 -Djavax.net.ssl.trustStorePassword=EipPass123! -Djdk.tls.client.protocols=TLSv1.2"

# Compatibility Alias for Phase 2 Initialization
export QUARKUS_DATASOURCE_JDBC_URL="${QUARKUS_DATASOURCE_EIP_JDBC_URL}"
export QUARKUS_DATASOURCE_USERNAME="${QUARKUS_DATASOURCE_EIP_USERNAME}"
export QUARKUS_DATASOURCE_PASSWORD="${QUARKUS_DATASOURCE_EIP_PASSWORD}"

# 2. Agnostic Component Registry

# 3. Discovery Engine Filter
EIP_IGNORE_INFRA=ibmmq,kafka,mongodb,redis
export EIP_LIQUIBASE_ENABLED="true"

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
