# change-stream-ssl-oneway.env
# MODE: RS One-Way SSL / User Auth

# 1. INFRASTRUCTURE FEATURES
EIP_MONGO_PORT=27030
EIP_MONGO_ROOT_USER=eip_admin
EIP_MONGO_ROOT_PASS=eip_password
EIP_MONGO_CMD_ARGS="--auth --bind_ip_all --replSet rs0 --tlsMode requireTLS --tlsCertificateKeyFile /etc/mongodb/certs/mongodb.pem --tlsCAFile /etc/mongodb/certs/root.crt --tlsAllowConnectionsWithoutCertificates --keyFile /tmp/replica.key"

# 2. PLATFORM PATHS
EIP_ROUTES_DIR="${BASE_DIR}/04_routes"
EIP_CONFIG_DIR="${EIP_ROUTES_DIR}"
CAMEL_COMPONENT_KAMELET_LOCATION="file://${BASE_DIR}/../../platform/kamelets/mongodb,file://${BASE_DIR}/../../platform/kamelets"

# 3. QUARKUS / CAMEL SECURITY BRIDGE
QUARKUS_TLS_MONGO_TRUST_STORE_PEM_CERTS="${EIP_CERT_DIR}/root.crt"
QUARKUS_MONGODB_CLIENT1_TLS_CONFIGURATION_NAME=mongo
QUARKUS_MONGODB_CLIENT1_CONNECTION_STRING="mongodb://eip_admin:eip_password@127.0.0.1:27030/eip_db?authSource=admin&tls=true&tlsAllowInvalidHostnames=true&directConnection=true"

# 4. JAVA_OPTS FOR LIQUIBASE / CLI TOOLS
export JAVA_OPTS="-Djavax.net.ssl.trustStore=${EIP_CERT_DIR}/truststore.p12 -Djavax.net.ssl.trustStorePassword=changeit -Djavax.net.ssl.trustStoreType=PKCS12"

# 5. AGNOSTIC SETTINGS
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_LOG_LEVEL=INFO
