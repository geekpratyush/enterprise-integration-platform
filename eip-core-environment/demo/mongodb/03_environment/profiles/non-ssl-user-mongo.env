# non-ssl-user-mongo.env
# MODE: SCRAM-SHA Auth / No SSL

# 1. INFRASTRUCTURE FEATURES
EIP_MONGO_PORT=27020
EIP_MONGO_ROOT_USER=eip_admin
EIP_MONGO_ROOT_PASS=eip_password
EIP_MONGO_CMD_ARGS="--auth --bind_ip_all"

# 2. PLATFORM PATHS
EIP_ROUTES_DIR="${BASE_DIR}/04_routes"
CAMEL_COMPONENT_KAMELET_LOCATION="file://${BASE_DIR}/../../platform/kamelets/mongodb,file://${BASE_DIR}/../../platform/kamelets"

# 3. MONGODB CLIENT 1 (Auth)
QUARKUS_MONGODB_CLIENT1_CONNECTION_STRING=mongodb://eip_admin:eip_password@127.0.0.1:27020/eip_db?authSource=admin

# 4. AGNOSTIC SETTINGS
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_LOG_LEVEL=INFO

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/test-routes/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
