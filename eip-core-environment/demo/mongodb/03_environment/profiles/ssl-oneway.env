# ssl-oneway.env
# MODE: One-Way SSL / User Auth

# 1. INFRASTRUCTURE FEATURES
EIP_MONGO_PORT=27020
EIP_MONGO_ROOT_USER=eip_admin
EIP_MONGO_ROOT_PASS=eip_password
EIP_MONGO_CMD_ARGS="--auth --bind_ip_all --tlsMode requireTLS --tlsCertificateKeyFile /etc/mongodb/certs/mongodb.pem --tlsCAFile /etc/mongodb/certs/root.crt --tlsAllowConnectionsWithoutCertificates"

# 2. PLATFORM PATHS
EIP_ROUTES_DIR="${BASE_DIR}/04_routes"
CAMEL_COMPONENT_KAMELET_LOCATION="file://${BASE_DIR}/../../platform/kamelets/mongodb"

# 3. QUARKUS / CAMEL SECURITY BRIDGE
QUARKUS_TLS_MONGO_TRUST_STORE_PEM_CERTS="${EIP_CERT_DIR}/root.crt"
QUARKUS_MONGODB_CLIENT1_TLS_CONFIGURATION_NAME=mongo
QUARKUS_MONGODB_CLIENT1_CONNECTION_STRING="mongodb://eip_admin:eip_password@127.0.0.1:27020/eip_db?authSource=admin&tls=true&tlsAllowInvalidHostnames=true"

# 4. JAVA_OPTS FOR LIQUIBASE / CLI TOOLS
export JAVA_OPTS="-Djavax.net.ssl.trustStore=${EIP_CERT_DIR}/truststore.p12 -Djavax.net.ssl.trustStorePassword=changeit -Djavax.net.ssl.trustStoreType=PKCS12"

# 5. AGNOSTIC SETTINGS
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_LOG_LEVEL=INFO

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/test-routes/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
