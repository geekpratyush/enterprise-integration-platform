# solace-mtls.env
# MODE: Solace Mutual TLS Mission
# PORT: 55443

# ---------------------------------------------------------------------------
# PLATFORM INFRASTRUCTURE
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# ZERO-CODE KAMELET OVERRIDES (Auto-Wiring)
# ---------------------------------------------------------------------------

# --- Global Params ---
SOLACE_HOST=smfs://127.0.0.1:55443
SOLACE_VPN=default

# Auto-wiring for 'solace-source'
CAMEL_KAMELET_SOLACE_SOURCE_HOST=${SOLACE_HOST}
CAMEL_KAMELET_SOLACE_SOURCE_VPN=${SOLACE_VPN}
CAMEL_KAMELET_SOLACE_SOURCE_QUEUENAME=Q.DEMO.MTLS
CAMEL_KAMELET_SOLACE_SOURCE_SSLVALIDATECERTIFICATE=false
CAMEL_KAMELET_SOLACE_SOURCE_SSLTRUSTSTOREPATH=${EIP_CERT_DIR}/client-trust.p12
CAMEL_KAMELET_SOLACE_SOURCE_SSLTRUSTSTOREPASSWORD=password
CAMEL_KAMELET_SOLACE_SOURCE_SSLTRUSTSTOREFORMAT=PKCS12
CAMEL_KAMELET_SOLACE_SOURCE_SSLKEYSTOREPATH=${EIP_CERT_DIR}/client.p12
CAMEL_KAMELET_SOLACE_SOURCE_SSLKEYSTOREPASSWORD=password
CAMEL_KAMELET_SOLACE_SOURCE_SSLKEYSTOREFORMAT=PKCS12

# Auto-wiring for 'solace-sink'
CAMEL_KAMELET_SOLACE_SINK_HOST=${SOLACE_HOST}
CAMEL_KAMELET_SOLACE_SINK_VPN=${SOLACE_VPN}
CAMEL_KAMELET_SOLACE_SINK_QUEUENAME=Q.DEMO.MTLS
CAMEL_KAMELET_SOLACE_SINK_SSLVALIDATECERTIFICATE=false
CAMEL_KAMELET_SOLACE_SINK_SSLTRUSTSTOREPATH=${EIP_CERT_DIR}/client-trust.p12
CAMEL_KAMELET_SOLACE_SINK_SSLTRUSTSTOREPASSWORD=password
CAMEL_KAMELET_SOLACE_SINK_SSLTRUSTSTOREFORMAT=PKCS12
CAMEL_KAMELET_SOLACE_SINK_SSLKEYSTOREPATH=${EIP_CERT_DIR}/client.p12
CAMEL_KAMELET_SOLACE_SINK_SSLKEYSTOREPASSWORD=password
CAMEL_KAMELET_SOLACE_SINK_SSLKEYSTOREFORMAT=PKCS12

# ---------------------------------------------------------------------------
# QUARKUS & PLATFORM METADATA
# ---------------------------------------------------------------------------
QUARKUS_PROFILE=prod
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
