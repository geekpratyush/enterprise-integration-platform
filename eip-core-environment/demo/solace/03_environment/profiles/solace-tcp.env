# solace-tcp.env
# MODE: Solace Plaintext Mission
# PORT: 55555

# ---------------------------------------------------------------------------
# PLATFORM INFRASTRUCTURE
# ---------------------------------------------------------------------------
# (Broker usually handled by 01_provisioning)

# ---------------------------------------------------------------------------
# ZERO-CODE KAMELET OVERRIDES (Auto-Wiring)
# ---------------------------------------------------------------------------
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# --- Global Params ---
SOLACE_HOST=smf://localhost:55555
SOLACE_VPN=default
SOLACE_USER=default
SOLACE_PASS=default

# Auto-wiring for 'solace-source'
CAMEL_KAMELET_SOLACE_SOURCE_HOST=${SOLACE_HOST}
CAMEL_KAMELET_SOLACE_SOURCE_VPN=${SOLACE_VPN}
CAMEL_KAMELET_SOLACE_SOURCE_USERNAME=${SOLACE_USER}
CAMEL_KAMELET_SOLACE_SOURCE_PASSWORD=${SOLACE_PASS}
CAMEL_KAMELET_SOLACE_SOURCE_QUEUENAME=Q.DEMO.1

# Auto-wiring for 'solace-sink'
CAMEL_KAMELET_SOLACE_SINK_HOST=${SOLACE_HOST}
CAMEL_KAMELET_SOLACE_SINK_VPN=${SOLACE_VPN}
CAMEL_KAMELET_SOLACE_SINK_USERNAME=${SOLACE_USER}
CAMEL_KAMELET_SOLACE_SINK_PASSWORD=${SOLACE_PASS}
CAMEL_KAMELET_SOLACE_SINK_QUEUENAME=Q.DEMO.1

# ---------------------------------------------------------------------------
# QUARKUS & PLATFORM METADATA
# ---------------------------------------------------------------------------
QUARKUS_PROFILE=prod
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
