# ssl-jms/envs/ssl-jms.env
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"
EIP_ROUTE_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/solace/routes/ssl-jms

# Solace Source (using smfs:// for SSL)
CAMEL_KAMELET_SOLACE_SOURCE_HOST=smfs://127.0.0.1:55443
CAMEL_KAMELET_SOLACE_SOURCE_VPN=default
CAMEL_KAMELET_SOLACE_SOURCE_USERNAME=default
CAMEL_KAMELET_SOLACE_SOURCE_PASSWORD=default
CAMEL_KAMELET_SOLACE_SOURCE_QUEUENAME=Q.DEMO.SSL
CAMEL_KAMELET_SOLACE_SOURCE_SSLVALIDATECERTIFICATE=false
CAMEL_KAMELET_SOLACE_SOURCE_SSLTRUSTSTOREPATH=${EIP_CERT_DIR}/client-trust.p12
CAMEL_KAMELET_SOLACE_SOURCE_SSLTRUSTSTOREPASSWORD=changeit
CAMEL_KAMELET_SOLACE_SOURCE_SSLTRUSTSTOREFORMAT=PKCS12

# Solace Sink
CAMEL_KAMELET_SOLACE_SINK_HOST=smfs://127.0.0.1:55443
CAMEL_KAMELET_SOLACE_SINK_VPN=default
CAMEL_KAMELET_SOLACE_SINK_USERNAME=default
CAMEL_KAMELET_SOLACE_SINK_PASSWORD=default
CAMEL_KAMELET_SOLACE_SINK_QUEUENAME=Q.DEMO.SSL
CAMEL_KAMELET_SOLACE_SINK_SSLVALIDATECERTIFICATE=false
CAMEL_KAMELET_SOLACE_SINK_SSLTRUSTSTOREPATH=${EIP_CERT_DIR}/client-trust.p12
CAMEL_KAMELET_SOLACE_SINK_SSLTRUSTSTOREPASSWORD=changeit
CAMEL_KAMELET_SOLACE_SINK_SSLTRUSTSTOREFORMAT=PKCS12

# Quarkus / MongoDB Disabling

# Relational Database (JDBC) is strictly disabled
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_DATASOURCE_USERNAME=none
QUARKUS_DATASOURCE_PASSWORD=none
QUARKUS_DATASOURCE_JDBC_URL=jdbc:none

# MongoDB is strictly disabled to prevent connection errors
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
