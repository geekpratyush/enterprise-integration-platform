# tcp-noauth.env
# MODE: Solace Plaintext (No Auth)
# PORT: 55555 / VPN: default

EIP_ROUTES_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/solace/04_routes

# Auto-wiring
SOLACE_HOST=smf://127.0.0.1:55555
SOLACE_VPN=default
SOLACE_USER=default
SOLACE_PASS=default

CAMEL_KAMELET_SOLACE_SOURCE_HOST=${SOLACE_HOST}
CAMEL_KAMELET_SOLACE_SOURCE_VPN=${SOLACE_VPN}
CAMEL_KAMELET_SOLACE_SOURCE_USERNAME=${SOLACE_USER}
CAMEL_KAMELET_SOLACE_SOURCE_PASSWORD=${SOLACE_PASS}
CAMEL_KAMELET_SOLACE_SOURCE_QUEUENAME=Q.DEMO.1

CAMEL_KAMELET_SOLACE_SINK_HOST=${SOLACE_HOST}
CAMEL_KAMELET_SOLACE_SINK_VPN=${SOLACE_VPN}
CAMEL_KAMELET_SOLACE_SINK_USERNAME=${SOLACE_USER}
CAMEL_KAMELET_SOLACE_SINK_PASSWORD=${SOLACE_PASS}
CAMEL_KAMELET_SOLACE_SINK_QUEUENAME=Q.DEMO.1

# Standard Metadata
QUARKUS_PROFILE=prod
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_NETTY_NATIVE_TRANSPORT=false

# STRICT DISABLING (Referenced from mtls-jms.env)
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_DATASOURCE_USERNAME=none
QUARKUS_DATASOURCE_PASSWORD=none
QUARKUS_DATASOURCE_JDBC_URL=jdbc:none

QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://127.0.0.1:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
