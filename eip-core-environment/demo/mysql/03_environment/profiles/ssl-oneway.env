# MYSQL SSL ONEWAY PROFILE
export EIP_ROUTE_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/mysql/04_routes"
export EIP_CONFIG_DIR="${EIP_ROUTE_DIR}"
export EIP_CERT_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/mysql/02_initialization/certs"

# 1. Named DataSource: eip (SSL 1-Way)
# DEBUG MODE: Switched to sslMode=REQUIRED to verify network connectivity
export QUARKUS_DATASOURCE_EIP_JDBC_URL="jdbc:mysql://127.0.0.1:3306/eip_db?sslMode=REQUIRED"
export QUARKUS_DATASOURCE_EIP_USERNAME="eip_user"
export QUARKUS_DATASOURCE_EIP_PASSWORD="eip_password"
export QUARKUS_DATASOURCE_EIP_DB_KIND="mysql"

# MySQL Server Options (Mandatory for SSL Handshake)
export MYSQL_OPTS="--ssl-ca=/etc/mysql/certs/ca-cert.pem --ssl-cert=/etc/mysql/certs/server-cert.pem --ssl-key=/etc/mysql/certs/server-key.pem --require_secure_transport=ON"

# Quarkus Runtime Liquibase (Named DataSource: eip)
export QUARKUS_LIQUIBASE_EIP_MIGRATE_AT_START=true
export QUARKUS_LIQUIBASE_EIP_ENABLED=true
export QUARKUS_LIQUIBASE_EIP_CHANGE_LOG="filesystem:/home/pratyush/software/eip-core-integration/eip-core-environment/demo/mysql/02_initialization/changelog/db.changelog-master.yaml"

# SSL Metadata (Internal Platform Trust)
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStore=${EIP_CERT_DIR}/ssl-oneway/mysql-truststore.p12
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStorePassword=changeit
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStoreType=PKCS12

# Standard JAVA_OPTS for Liquibase and CLI tools
export JAVA_OPTS="-Djavax.net.ssl.trustStore=${EIP_CERT_DIR}/ssl-oneway/mysql-truststore.p12 -Djavax.net.ssl.trustStorePassword=changeit"

# Compatibility Alias for Phase 2 Initialization
export QUARKUS_DATASOURCE_JDBC_URL="${QUARKUS_DATASOURCE_EIP_JDBC_URL}"
export QUARKUS_DATASOURCE_USERNAME="${QUARKUS_DATASOURCE_EIP_USERNAME}"
export QUARKUS_DATASOURCE_PASSWORD="${QUARKUS_DATASOURCE_EIP_PASSWORD}"

# 2. Agnostic Component Registry (Explicit Property Mapping)
export export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# 3. Discovery Engine Filter
EIP_IGNORE_INFRA=ibmmq,kafka,mongodb,redis
export EIP_LIQUIBASE_ENABLED="true"
