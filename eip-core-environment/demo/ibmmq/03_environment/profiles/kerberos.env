# kerberos.env
# Kerberos (GSSAPI) Environment

# KAMELET LOCATION
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# JAAS / KERBEROS CONFIG
JAVA_TOOL_OPTIONS="-Djava.security.auth.login.config=${EIP_BASE_DIR}/eip-core-environment/demo/ibmmq/03_environment/kerberos/jaas.conf -Djava.security.krb5.conf=${EIP_BASE_DIR}/eip-core-environment/demo/ibmmq/03_environment/kerberos/krb5.conf"

# MQ KAMELET SINK (Kerberos Mode)
CAMEL_KAMELET_IBMMQ_SINK_HOSTNAME=localhost
CAMEL_KAMELET_IBMMQ_SINK_PORT=1414
CAMEL_KAMELET_IBMMQ_SINK_QUEUEMANAGER=QM1
CAMEL_KAMELET_IBMMQ_SINK_CHANNEL=DEV.APP.SVRCONN
CAMEL_KAMELET_IBMMQ_SINK_QUEUENAME=DEV.QUEUE.1
# Kerberos often uses 'MQAppClient' or similar JAAS entry
# No SSL - handled by GSSPI
CAMEL_KAMELET_IBMMQ_SINK_SSLCIPHERSUITE=

# MQ KAMELET SOURCE (Kerberos Mode)
CAMEL_KAMELET_IBMMQ_SOURCE_T1_HOSTNAME=localhost
CAMEL_KAMELET_IBMMQ_SOURCE_T1_PORT=1414
CAMEL_KAMELET_IBMMQ_SOURCE_T1_QUEUEMANAGER=QM1
CAMEL_KAMELET_IBMMQ_SOURCE_T1_CHANNEL=DEV.APP.SVRCONN
CAMEL_KAMELET_IBMMQ_SOURCE_T1_QUEUENAME=DEV.QUEUE.1
CAMEL_KAMELET_IBMMQ_SOURCE_T1_SSLCIPHERSUITE=

# AGNOSTIC SETTINGS
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_LOG_LEVEL=INFO
