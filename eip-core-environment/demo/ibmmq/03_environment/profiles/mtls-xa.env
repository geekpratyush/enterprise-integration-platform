# mtls-xa.env
# Mutual TLS (mTLS) + Global XA Transaction Mode

# KAMELET LOCATION
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/ibmmq"

# MQ KAMELET SINK (XA Mode - mTLS)
CAMEL_KAMELET_IBMMQ_SINK_HOSTNAME=localhost
CAMEL_KAMELET_IBMMQ_SINK_PORT=1414
CAMEL_KAMELET_IBMMQ_SINK_QUEUEMANAGER=QM1
CAMEL_KAMELET_IBMMQ_SINK_CHANNEL=DEV.APP.SVRCONN
CAMEL_KAMELET_IBMMQ_SINK_QUEUENAME=DEV.QUEUE.1
# XA Master Switch
CAMEL_KAMELET_IBMMQ_SINK_TRANSACTED=true
CAMEL_KAMELET_IBMMQ_SINK_USEXA=true
# mTLS for XA
CAMEL_KAMELET_IBMMQ_SINK_AUTHENTICATIONMQCSP=false
CAMEL_KAMELET_IBMMQ_SINK_SSLCIPHERSUITE=TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
CAMEL_KAMELET_IBMMQ_SINK_USEIBMCIPHERMAPPINGS=false
CAMEL_KAMELET_IBMMQ_SINK_TRUSTSTOREPATH=${EIP_CERT_DIR}/mqserver.p12
CAMEL_KAMELET_IBMMQ_SINK_TRUSTSTOREPASSWORD=changeit
CAMEL_KAMELET_IBMMQ_SINK_KEYSTOREPATH=${EIP_CERT_DIR}/client-key.p12
CAMEL_KAMELET_IBMMQ_SINK_KEYSTOREPASSWORD=changeit

# MQ KAMELET SOURCE (XA Mode - mTLS - Silo T1)
CAMEL_KAMELET_IBMMQ_SOURCE_T1_HOSTNAME=localhost
CAMEL_KAMELET_IBMMQ_SOURCE_T1_PORT=1414
CAMEL_KAMELET_IBMMQ_SOURCE_T1_QUEUEMANAGER=QM1
CAMEL_KAMELET_IBMMQ_SOURCE_T1_CHANNEL=DEV.APP.SVRCONN
CAMEL_KAMELET_IBMMQ_SOURCE_T1_QUEUENAME=DEV.QUEUE.1
# XA Master Switch
CAMEL_KAMELET_IBMMQ_SOURCE_T1_TRANSACTED=true
CAMEL_KAMELET_IBMMQ_SOURCE_T1_USEXA=true
CAMEL_KAMELET_IBMMQ_SOURCE_T1_AUTHENTICATIONMQCSP=false
CAMEL_KAMELET_IBMMQ_SOURCE_T1_SSLCIPHERSUITE=TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
CAMEL_KAMELET_IBMMQ_SOURCE_T1_USEIBMCIPHERMAPPINGS=false
CAMEL_KAMELET_IBMMQ_SOURCE_T1_TRUSTSTOREPATH=${EIP_CERT_DIR}/mqserver.p12
CAMEL_KAMELET_IBMMQ_SOURCE_T1_TRUSTSTOREPASSWORD=changeit
CAMEL_KAMELET_IBMMQ_SOURCE_T1_KEYSTOREPATH=${EIP_CERT_DIR}/client-key.p12
CAMEL_KAMELET_IBMMQ_SOURCE_T1_KEYSTOREPASSWORD=changeit

# GLOBAL TRANSACTION ACTIVATION
EIP_JTA_ENABLED=true
EIP_NARAYANA_ENABLED=true

# AGNOSTIC SETTINGS
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_LOG_LEVEL=INFO
