# kerberos-jms/envs/kerberos-jms.env
# Kerberos-JMS Environment (GSSAPI Authentication)
EIP_CONFIG_DIR=
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"
EIP_ROUTE_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/ibmmq/routes/kerberos-jms

# IBM MQ Source
CAMEL_KAMELET_IBMMQ_SOURCE_HOSTNAME=localhost
CAMEL_KAMELET_IBMMQ_SOURCE_PORT=1415
CAMEL_KAMELET_IBMMQ_SOURCE_QUEUEMANAGER=QM_SSL
CAMEL_KAMELET_IBMMQ_SOURCE_CHANNEL=DEV.APP.SVRCONN
CAMEL_KAMELET_IBMMQ_SOURCE_QUEUENAME=DEV.QUEUE.1
CAMEL_KAMELET_IBMMQ_SOURCE_AUTHENTICATIONMQCSP=true
CAMEL_KAMELET_IBMMQ_SOURCE_AUTHENTICATIONTYPE=4
# Kerberos requires JAAS configuration automatically generated by kerberos-jms.sh
export JAVA_TOOL_OPTIONS="-Djava.security.auth.login.config=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/ibmmq/config/kerberos-jms/envs/jaas.conf -Djava.security.krb5.conf=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/ibmmq/config/kerberos-jms/envs/krb5.conf"
CAMEL_KAMELET_IBMMQ_SOURCE_SSLCIPHERSUITE=TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
CAMEL_KAMELET_IBMMQ_SOURCE_DEBUGSSL=false
CAMEL_KAMELET_IBMMQ_SOURCE_TRUSTSTOREPATH=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/ibmmq/config/kerberos-jms/certs/client-trust.p12
CAMEL_KAMELET_IBMMQ_SOURCE_TRUSTSTOREPASSWORD=changeit

# IBM MQ Sink
CAMEL_KAMELET_IBMMQ_SINK_T2_HOSTNAME=localhost
CAMEL_KAMELET_IBMMQ_SINK_T2_PORT=1415
CAMEL_KAMELET_IBMMQ_SINK_T2_QUEUEMANAGER=QM_SSL
CAMEL_KAMELET_IBMMQ_SINK_T2_CHANNEL=DEV.APP.SVRCONN
CAMEL_KAMELET_IBMMQ_SINK_T2_QUEUENAME=DEV.QUEUE.1
CAMEL_KAMELET_IBMMQ_SINK_T2_AUTHENTICATIONMQCSP=true
CAMEL_KAMELET_IBMMQ_SINK_T2_AUTHENTICATIONTYPE=4
CAMEL_KAMELET_IBMMQ_SINK_T2_SSLCIPHERSUITE=TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
CAMEL_KAMELET_IBMMQ_SINK_T2_DEBUGSSL=false
CAMEL_KAMELET_IBMMQ_SINK_T2_TRUSTSTOREPATH=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/ibmmq/config/kerberos-jms/certs/client-trust.p12
CAMEL_KAMELET_IBMMQ_SINK_T2_TRUSTSTOREPASSWORD=changeit

# Quarkus / MongoDB Disabling (Standard)

# Relational Database (JDBC) is strictly disabled
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_DATASOURCE_USERNAME=none
QUARKUS_DATASOURCE_PASSWORD=none
QUARKUS_DATASOURCE_JDBC_URL=jdbc:none

# MongoDB is strictly disabled to prevent connection errors
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF
