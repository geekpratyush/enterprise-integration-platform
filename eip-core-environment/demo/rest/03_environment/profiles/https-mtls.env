# https-mtls.env
WIREMOCK_HTTPS_PORT=8443
WIREMOCK_KEYSTORE=/home/wiremock/certs/keystore.jks
WIREMOCK_KEYSTORE_PASSWORD=changeit
WIREMOCK_TRUSTSTORE=/home/wiremock/certs/truststore.jks
WIREMOCK_TRUSTSTORE_PASSWORD=changeit
WIREMOCK_REQUIRE_CLIENT_CERT=true
WIRE_MOCK_URL=https://localhost:8443

# PLATFORM PATHS
EIP_ROUTES_DIR="${BASE_DIR}/04_routes"

# EIP TLS REGISTRY BRIDGE (Managed JKS/P12)
QUARKUS_TLS_REST_TRUST_STORE_JKS_PATH="${EIP_CERT_DIR}/truststore.jks"
QUARKUS_TLS_REST_TRUST_STORE_JKS_PASSWORD="changeit"
QUARKUS_TLS_REST_KEY_STORE_P12_PATH="${EIP_CERT_DIR}/client.p12"
QUARKUS_TLS_REST_KEY_STORE_P12_PASSWORD="changeit"
EIP_TLS_FLAG="&sslContextParameters=#rest"

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
