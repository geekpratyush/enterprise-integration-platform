{
  "mappings": [
    {
      "request": {
        "method": "GET",
        "urlPathPattern": "/api/fault/500.*"
      },
      "response": {
        "status": 500,
        "body": "{\"error\": \"Internal Server Error\"}"
      }
    },
    {
      "request": {
        "method": "GET",
        "urlPath": "/api/fault/timeout"
      },
      "response": {
        "status": 200,
        "fixedDelayMilliseconds": 10000,
        "body": "{\"status\": \"Delayed Success\"}"
      }
    }
  ]
}
