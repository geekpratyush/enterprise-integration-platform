# --- EIP Platform Environment: OpenAPI Mission ---
EIP_REST_CONTEXT_PATH=/
EIP_REST_API_PATH=/api-doc

# --- Routes Configuration ---
# Paths are dynamically resolved by setup-env.sh
EIP_UI_DIR=${EIP_ROUTES_DIR}/ui

# --- Camel Route Discovery (NATIVE MODE) ---

# Disable custom bootstrap for this test

# --- Camel OpenAPI Metadata ---
CAMEL_QUARKUS_OPENAPI_EXPOSE_TO_SMALLRYE_OPENAPI=true
CAMEL_QUARKUS_OPENAPI_ADD_SWAGGER_UI_URL=false

# --- Auditing & Storage (SILENCED) ---
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false

# --- Swagger UI Discovery ---
QUARKUS_SWAGGER_UI_PATH=/docs
QUARKUS_SWAGGER_UI_ALWAYS_INCLUDE=true
QUARKUS_SWAGGER_UI_URLS_FUEL=/api-doc
QUARKUS_SWAGGER_UI_URLS_ENGINE=/q/openapi
QUARKUS_SWAGGER_UI_IGNORE_DISCOVERED=true

# --- Mission Control Footer ---
EIP_MISSION_ID=OPENAPI_TRANSFORMER
EIP_UI_FOOTER='<script src="/fuel-ui/swagger-monaco.js"></script><div style="display:flex; gap:10px; padding:15px; background: #0f172a; border-radius: 8px; margin: 10px; border: 1px solid #334155; justify-content: center;"><a href="/fuel-ui/mt-to-mx.html" target="_blank" style="color:#38bdf8; font-weight:800; text-decoration:none; font-family: Inter, sans-serif; font-size: 13px;">🚀 MT to MX</a><span style="color:#334155;">|</span><a href="/fuel-ui/mx-to-mt.html" target="_blank" style="color:#fbbf24; font-weight:800; text-decoration:none; font-family: Inter, sans-serif; font-size: 13px;">⚡ MX to MT</a><span style="color:#334155;">|</span><a href="/api-doc" target="_blank" style="color:#94a3b8; font-weight:800; text-decoration:none; font-family: Inter, sans-serif; font-size: 13px;">📖 API Docs</a></div>'
# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
