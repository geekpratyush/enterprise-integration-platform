# non-ssl-sqlserver.env
export EIP_ROUTE_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/sqlserver/04_routes
export EIP_CONFIG_DIR=${EIP_ROUTE_DIR}

# 1. Named DataSource: eip (For Camel Registry)
export QUARKUS_DATASOURCE_EIP_JDBC_URL="jdbc:sqlserver://127.0.0.1:1433;databaseName=eip_db;encrypt=false"
export QUARKUS_DATASOURCE_EIP_USERNAME=eip_user
export QUARKUS_DATASOURCE_EIP_PASSWORD="Password123!"
export QUARKUS_DATASOURCE_EIP_DB_KIND=mssql

# Compatibility Alias (For Initialization Scripts)
export QUARKUS_DATASOURCE_JDBC_URL="${QUARKUS_DATASOURCE_EIP_JDBC_URL}"
export QUARKUS_DATASOURCE_USERNAME="${QUARKUS_DATASOURCE_EIP_USERNAME}"
export QUARKUS_DATASOURCE_PASSWORD="${QUARKUS_DATASOURCE_EIP_PASSWORD}"

# Kamelet Auto-Injection
export CAMEL_KAMELET_SQLSERVER_SINK_SERVERNAME=127.0.0.1
export CAMEL_KAMELET_SQLSERVER_SINK_SERVERPORT=1433
export CAMEL_KAMELET_SQLSERVER_SINK_USERNAME=eip_user
export CAMEL_KAMELET_SQLSERVER_SINK_PASSWORD=Password123!
export CAMEL_KAMELET_SQLSERVER_SINK_DATABASENAME=eip_db

# Quarkus Runtime Liquibase
export QUARKUS_LIQUIBASE_EIP_MIGRATE_AT_START=true
export QUARKUS_LIQUIBASE_EIP_ENABLED=true
export QUARKUS_LIQUIBASE_EIP_CHANGE_LOG="filesystem:/home/pratyush/software/eip-core-integration/eip-core-environment/demo/sqlserver/02_initialization/changelog/db.changelog-master.yaml"



# Infrastructure Mode
export MODE=non-ssl-sqlserver
export MSSQL_OPTS=""

# 3. Agnostic Component Registry
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# 4. Discovery Engine Filter
EIP_IGNORE_INFRA=ibmmq,kafka,mongodb,redis
export EIP_LIQUIBASE_ENABLED="true"
