# non-ssl-kafka.env
# MODE: Kafka Plaintext Mission (Confluent)
# PORT: 9092

# ---------------------------------------------------------------------------
# PLATFORM INFRASTRUCTURE (Broker Configuration)
# ---------------------------------------------------------------------------
EIP_KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093,DOCKER://0.0.0.0:29092
EIP_KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092,DOCKER://kafka-platform:29092
EIP_KAFKA_SEC_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT,INTERNAL:PLAINTEXT,DOCKER:PLAINTEXT

# ---------------------------------------------------------------------------
# ZERO-CODE KAMELET OVERRIDES (Auto-Wiring)
# ---------------------------------------------------------------------------
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# --- Global Source Parameters ---
KAFKA_BOOTSTRAP=127.0.0.1:9092

# Auto-wiring for 'kafka-source'
CAMEL_KAMELET_KAFKA_SOURCE_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP}
CAMEL_KAMELET_KAFKA_SOURCE_TOPIC=audit_log
CAMEL_KAMELET_KAFKA_SOURCE_CONSUMER_GROUP=eip-consumer-group
CAMEL_KAMELET_KAFKA_SOURCE_AUTO_OFFSET_RESET=earliest
CAMEL_KAMELET_KAFKA_SOURCE_SECURITY_PROTOCOL=PLAINTEXT
CAMEL_KAMELET_KAFKA_SOURCE_SASL_AUTH_TYPE=NONE

# Auto-wiring for 'kafka-batch-source'
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP}
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SECURITY_PROTOCOL=PLAINTEXT
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SASL_AUTH_TYPE=NONE

# Auto-wiring for 'kafka-sink'
CAMEL_KAMELET_KAFKA_SINK_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP}
CAMEL_KAMELET_KAFKA_SINK_TOPIC=audit_log
CAMEL_KAMELET_KAFKA_SINK_SECURITY_PROTOCOL=PLAINTEXT
CAMEL_KAMELET_KAFKA_SINK_SASL_AUTH_TYPE=NONE

# ---------------------------------------------------------------------------
# QUARKUS & PLATFORM METADATA
# ---------------------------------------------------------------------------
QUARKUS_PROFILE=prod
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false
