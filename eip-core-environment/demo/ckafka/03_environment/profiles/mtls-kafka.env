# mtls-kafka.env
# MODE: Kafka Mutual TLS Mission (Confluent)
# PORT: 9095

# ---------------------------------------------------------------------------
# PLATFORM INFRASTRUCTURE (Broker Configuration)
# ---------------------------------------------------------------------------
EIP_KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093,DOCKER://0.0.0.0:29092,SSL://0.0.0.0:9095
EIP_KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092,DOCKER://kafka-platform:29092,SSL://localhost:9095
EIP_KAFKA_SEC_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT,INTERNAL:PLAINTEXT,DOCKER:PLAINTEXT,SSL:SSL

# Broker SSL Identity & Trust
EIP_KAFKA_SSL_KEYSTORE_LOCATION=/etc/kafka/secrets/audit-keystore.p12
EIP_KAFKA_SSL_KEYSTORE_FILENAME=audit-keystore.p12
EIP_KAFKA_SSL_KEYSTORE_CREDENTIALS=password
EIP_KAFKA_SSL_KEY_CREDENTIALS=password
EIP_KAFKA_SSL_KEY_PASSWORD=password
EIP_KAFKA_SSL_KEYSTORE_TYPE=PKCS12
EIP_KAFKA_SSL_TRUSTSTORE_LOCATION=/etc/kafka/secrets/audit-truststore.p12
EIP_KAFKA_SSL_TRUSTSTORE_FILENAME=audit-truststore.p12
EIP_KAFKA_SSL_TRUSTSTORE_CREDENTIALS=password
EIP_KAFKA_SSL_TRUSTSTORE_TYPE=PKCS12
EIP_KAFKA_SSL_CLIENT_AUTH=required

# --- Global Source Parameters ---
KAFKA_BOOTSTRAP=127.0.0.1:9095

# Auto-wiring for 'kafka-source'
CAMEL_KAMELET_KAFKA_SOURCE_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP}
CAMEL_KAMELET_KAFKA_SOURCE_TOPIC=audit_log
CAMEL_KAMELET_KAFKA_SOURCE_CONSUMER_GROUP=eip-consumer-group
CAMEL_KAMELET_KAFKA_SOURCE_AUTO_OFFSET_RESET=earliest
CAMEL_KAMELET_KAFKA_SOURCE_SECURITY_PROTOCOL=SSL
CAMEL_KAMELET_KAFKA_SOURCE_SASL_AUTH_TYPE=SSL
CAMEL_KAMELET_KAFKA_SOURCE_SSL_KEYSTORE_LOCATION=${EIP_CERT_DIR}/client.keystore.p12
CAMEL_KAMELET_KAFKA_SOURCE_SSL_KEYSTORE_PASSWORD=password
CAMEL_KAMELET_KAFKA_SOURCE_SSL_KEYSTORE_TYPE=PKCS12
CAMEL_KAMELET_KAFKA_SOURCE_SSL_TRUSTSTORE_LOCATION=${EIP_CERT_DIR}/audit-truststore.p12
CAMEL_KAMELET_KAFKA_SOURCE_SSL_TRUSTSTORE_PASSWORD=password
CAMEL_KAMELET_KAFKA_SOURCE_SSL_TRUSTSTORE_TYPE=PKCS12

# Auto-wiring for 'kafka-batch-source'
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP}
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SECURITY_PROTOCOL=SSL
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SASL_AUTH_TYPE=SSL
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SSL_KEYSTORE_LOCATION=${EIP_CERT_DIR}/client.keystore.p12
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SSL_KEYSTORE_PASSWORD=password
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SSL_KEYSTORE_TYPE=PKCS12
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SSL_TRUSTSTORE_LOCATION=${EIP_CERT_DIR}/audit-truststore.p12
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SSL_TRUSTSTORE_PASSWORD=password
CAMEL_KAMELET_KAFKA_BATCH_SOURCE_SSL_TRUSTSTORE_TYPE=PKCS12

# Auto-wiring for 'kafka-sink'
CAMEL_KAMELET_KAFKA_SINK_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP}
CAMEL_KAMELET_KAFKA_SINK_TOPIC=audit_log
CAMEL_KAMELET_KAFKA_SINK_SECURITY_PROTOCOL=SSL
CAMEL_KAMELET_KAFKA_SINK_SASL_AUTH_TYPE=SSL
CAMEL_KAMELET_KAFKA_SINK_SSL_KEYSTORE_LOCATION=${EIP_CERT_DIR}/client.keystore.p12
CAMEL_KAMELET_KAFKA_SINK_SSL_KEYSTORE_PASSWORD=password
CAMEL_KAMELET_KAFKA_SINK_SSL_KEYSTORE_TYPE=PKCS12
CAMEL_KAMELET_KAFKA_SINK_SSL_TRUSTSTORE_LOCATION=${EIP_CERT_DIR}/audit-truststore.p12
CAMEL_KAMELET_KAFKA_SINK_SSL_TRUSTSTORE_PASSWORD=password
CAMEL_KAMELET_KAFKA_SINK_SSL_TRUSTSTORE_TYPE=PKCS12

# ---------------------------------------------------------------------------
# CAMEL NATIVE ROUTE DISCOVERY
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# QUARKUS & PLATFORM METADATA
# ---------------------------------------------------------------------------
QUARKUS_PROFILE=prod
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
