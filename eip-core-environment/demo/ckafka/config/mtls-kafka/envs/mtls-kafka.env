# .env (mtls-kafka)
EIP_CONFIG_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/kafka/routes/mtls-kafka
EIP_CERT_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/kafka/config/mtls-kafka/certs

# 1. GLOBAL QUARKUS KAFKA PROPERTIES
QUARKUS_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9095
QUARKUS_KAFKA_SECURITY_PROTOCOL=SSL
QUARKUS_KAFKA_SSL_KEYSTORE_LOCATION=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/kafka/config/mtls-kafka/certs/client.keystore.p12
QUARKUS_KAFKA_SSL_KEYSTORE_PASSWORD=password
QUARKUS_KAFKA_SSL_KEYSTORE_TYPE=PKCS12
QUARKUS_KAFKA_SSL_KEY_PASSWORD=password
QUARKUS_KAFKA_SSL_TRUSTSTORE_LOCATION=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/kafka/config/mtls-kafka/certs/audit-truststore.p12
QUARKUS_KAFKA_SSL_TRUSTSTORE_PASSWORD=password
QUARKUS_KAFKA_SSL_TRUSTSTORE_TYPE=PKCS12
QUARKUS_KAFKA_SSL_ENDPOINT_IDENTIFICATION_ALGORITHM=

# 2. KAMELET OVERRIDES (Optional, as the 'kafka' component bean handles the heavy lifting)
CAMEL_KAMELET_KAFKA_SOURCE_BOOTSTRAP_SERVERS=127.0.0.1:9095
CAMEL_KAMELET_KAFKA_SOURCE_SECURITY_PROTOCOL=SSL
CAMEL_KAMELET_KAFKA_SINK_BOOTSTRAP_SERVERS=127.0.0.1:9095
CAMEL_KAMELET_KAFKA_SINK_SECURITY_PROTOCOL=SSL

# Standard Logging/Suppression
QUARKUS_LOG_LEVEL=INFO
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA__LEVEL=INFO

# Relational Database (JDBC) is strictly disabled
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_DATASOURCE_USERNAME=none
QUARKUS_DATASOURCE_PASSWORD=none
QUARKUS_DATASOURCE_JDBC_URL=jdbc:none

# MongoDB is strictly disabled to prevent connection errors
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF
