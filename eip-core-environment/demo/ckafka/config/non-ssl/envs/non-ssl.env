# non-ssl.env
EIP_CONFIG_DIR=
EIP_ROUTE_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/kafka/routes/non-ssl

# Kafka Source
CAMEL_KAMELET_KAFKA_SOURCE_BOOTSTRAPSERVERS=localhost:9092
CAMEL_KAMELET_KAFKA_SOURCE_GROUPID=demo-group
CAMEL_KAMELET_KAFKA_SOURCE_SECURITYPROTOCOL=PLAINTEXT
CAMEL_KAMELET_KAFKA_SOURCE_AUTOOFFSETRESET=earliest

# Kafka Sink
CAMEL_KAMELET_KAFKA_SINK_BOOTSTRAPSERVERS=localhost:9092
CAMEL_KAMELET_KAFKA_SINK_SECURITYPROTOCOL=PLAINTEXT

# Standard Quartz/Mongodb suppression

# Kafka Logging Suppression (Driven from Environment)
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_COMMON__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_CLIENTS__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_CAMEL_COMPONENT_KAFKA__LEVEL=INFO
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_COMMON_TELEMETRY__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_COMMON_METRICS__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_CLIENTS_PRODUCER_INTERNALS_SENDER__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_CLIENTS_NETWORKCLIENT__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_CLIENTS_METADATA__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_COMMON_TELEMETRY_INTERNALS_KAFKAMETRICSCOLLECTOR__LEVEL=WARN
QUARKUS_LOG_CATEGORY__ORG_APACHE_KAFKA_COMMON_TELEMETRY_INTERNALS_CLIENT_TELEMETRY_REPORTER__LEVEL=OFF

# Relational Database (JDBC) is strictly disabled
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_DATASOURCE_USERNAME=none
QUARKUS_DATASOURCE_PASSWORD=none
QUARKUS_DATASOURCE_JDBC_URL=jdbc:none

# MongoDB is strictly disabled to prevent connection errors
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF
