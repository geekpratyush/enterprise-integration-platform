# redis-acl.env — ACL (User/Pass) Authentication
export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"
EIP_ROUTES_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/redis/04_routes

# Redis Connection (Quarkus standard)
QUARKUS_REDIS_HOSTS=redis://eip-user:eip-password@127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=eip-user
REDIS_PASSWORD=eip-password
REDIS_CHANNEL=eip-acl-channel
EIP_CERT_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/redis/02_initialization/certs
REDIS_TRUSTSTORE_PATH=${EIP_CERT_DIR}/redis-acl/redis-truststore.p12
REDIS_TRUSTSTORE_PASSWORD=changeit
REDIS_KEYSTORE_PATH=${EIP_CERT_DIR}/redis-acl/redis-client.p12
REDIS_KEYSTORE_PASSWORD=changeit

# Platform
QUARKUS_REDIS_DEVSERVICES_ENABLED=false
QUARKUS_PROFILE=prod
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_NETTY_NATIVE_TRANSPORT=false
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
