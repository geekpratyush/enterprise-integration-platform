# redis-auth.env
# MODE: Redis Standalone (TLS + ACL)
# PORT: 6379 (TLS)

EIP_ROUTES_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/redis/04_routes
EIP_CERT_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/redis/02_initialization/certs

# 1. Redis Identity (ACL)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=eip-user
REDIS_PASSWORD=eip-password
REDIS_CHANNEL=eip-tls-channel

# 2. Redis Security (TLS - Namespaced Registry)
CAMEL_COMPONENT_SPRING_REDIS_USE_SSL=true
CAMEL_COMPONENT_SPRING_REDIS_SSL_CONTEXT_PARAMETERS=#redis-pki

# 3. SSL Context Definition
CAMEL_SSL_REDIS_PKI_TRUST_MANAGERS_KEY_STORE_RESOURCE=file:${EIP_CERT_DIR}/redis-truststore.p12
CAMEL_SSL_REDIS_PKI_TRUST_MANAGERS_KEY_STORE_PASSWORD=changeit
CAMEL_SSL_REDIS_PKI_TRUST_MANAGERS_KEY_STORE_TYPE=PKCS12

# 4. Global Component Fallback (ACL Mapping)
CAMEL_COMPONENT_SPRING_REDIS_HOST=${REDIS_HOST}
CAMEL_COMPONENT_SPRING_REDIS_PORT=${REDIS_PORT}
CAMEL_COMPONENT_SPRING_REDIS_USERNAME=${REDIS_USER}
CAMEL_COMPONENT_SPRING_REDIS_PASSWORD=${REDIS_PASSWORD}

# 4. Kamelet Config (Catalog Sync)
# Note: Kamelets will inherit SSL/Discovery from the component fallback
CAMEL_KAMELET_REDIS_SINK_REDISHOST=${REDIS_HOST}
CAMEL_KAMELET_REDIS_SINK_REDISPORT=${REDIS_PORT}
CAMEL_KAMELET_REDIS_SINK_COMMAND=PUBLISH
CAMEL_KAMELET_REDIS_SINK_CHANNELS=${REDIS_CHANNEL}

CAMEL_KAMELET_REDIS_SOURCE_REDISHOST=${REDIS_HOST}
CAMEL_KAMELET_REDIS_SOURCE_REDISPORT=${REDIS_PORT}
CAMEL_KAMELET_REDIS_SOURCE_CHANNELS=${REDIS_CHANNEL}
CAMEL_KAMELET_REDIS_SOURCE_COMMAND=SUBSCRIBE

# Standard Metadata
QUARKUS_PROFILE=prod
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_NETTY_NATIVE_TRANSPORT=false

# STRICT DISABLING
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
