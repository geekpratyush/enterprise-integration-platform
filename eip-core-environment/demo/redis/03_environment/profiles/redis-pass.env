# redis-pass.env — Legacy Password
EIP_ROUTES_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/redis/04_routes

QUARKUS_REDIS_HOSTS=redis://:eip-password@127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=eip-password
REDIS_CHANNEL=eip-pass-channel

QUARKUS_PROFILE=prod
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
QUARKUS_REDIS_DEVSERVICES_ENABLED=false
QUARKUS_KAFKA_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_IBMMQ_ENABLED=false
QUARKUS_NETTY_NATIVE_TRANSPORT=false
QUARKUS_DATASOURCE_JDBC=false
QUARKUS_DATASOURCE_DB_KIND=none
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
