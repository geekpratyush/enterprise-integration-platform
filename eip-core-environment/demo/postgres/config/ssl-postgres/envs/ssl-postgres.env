# .env (ssl-postgres)
EIP_CONFIG_DIR=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/routes/ssl-postgres

# Datasource Settings (Camel SQL / Quarkus)
# SSL Mode set to verify-ca for security

# Standard Logging
QUARKUS_LOG_LEVEL=INFO
QUARKUS_LOG_CATEGORY__ORG_APACHE_CAMEL__LEVEL=INFO
QUARKUS_DATASOURCE_JDBC=true
QUARKUS_DATASOURCE_DB_KIND=postgresql
QUARKUS_DATASOURCE_USERNAME=eip_user
QUARKUS_DATASOURCE_PASSWORD=eip_password
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/eip_db?ssl=true&sslmode=verify-ca&sslrootcert=/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/config/ssl-postgres/certs/root.crt

# MongoDB is strictly disabled to prevent connection errors
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF
