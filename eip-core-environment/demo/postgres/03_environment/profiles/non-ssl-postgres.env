
# POSTGRES NON-SSL PROFILE
export EIP_ROUTE_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/04_routes"

# 1. Named DataSource: eip
export QUARKUS_DATASOURCE_EIP_JDBC_URL="jdbc:postgresql://127.0.0.1:5432/eip_db"
export QUARKUS_DATASOURCE_EIP_USERNAME="eip_user"
export QUARKUS_DATASOURCE_EIP_PASSWORD="eip_password"
export QUARKUS_DATASOURCE_EIP_DB_KIND="postgresql"

# Quarkus Runtime Liquibase (Named DataSource: eip)
export QUARKUS_LIQUIBASE_EIP_MIGRATE_AT_START=true
export QUARKUS_LIQUIBASE_EIP_ENABLED=true
export QUARKUS_LIQUIBASE_EIP_CHANGE_LOG="filesystem:/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/02_initialization/changelog/db.changelog-master.yaml"

# Compatibility Alias for Phase 2 Initialization
export QUARKUS_DATASOURCE_JDBC_URL="${QUARKUS_DATASOURCE_EIP_JDBC_URL}"
export QUARKUS_DATASOURCE_USERNAME="${QUARKUS_DATASOURCE_EIP_USERNAME}"
export QUARKUS_DATASOURCE_PASSWORD="${QUARKUS_DATASOURCE_EIP_PASSWORD}"

# 2. Agnostic Component Registry
export export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# 3. Discovery Engine Filter
EIP_IGNORE_INFRA=ibmmq,kafka,mongodb,redis
export EIP_LIQUIBASE_ENABLED="true"
# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
