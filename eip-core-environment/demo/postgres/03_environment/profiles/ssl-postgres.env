# POSTGRES mTLS PROFILE
export EIP_ROUTE_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/04_routes"
export EIP_CERT_DIR="/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/02_initialization/certs"

# 1. Named DataSource: eip (mTLS Track)
# Corrected folder name to ssl-postgres and key file to client-key.pk8
export QUARKUS_DATASOURCE_EIP_JDBC_URL="jdbc:postgresql://127.0.0.1:5432/eip_db?ssl=true&sslmode=verify-ca&sslrootcert=${EIP_CERT_DIR}/ssl-postgres/ca-cert.pem&sslcert=${EIP_CERT_DIR}/ssl-postgres/client-cert.pem&sslkey=${EIP_CERT_DIR}/ssl-postgres/client-key.pk8"
export QUARKUS_DATASOURCE_EIP_USERNAME="eip_user"
export QUARKUS_DATASOURCE_EIP_PASSWORD="eip_password"
export QUARKUS_DATASOURCE_EIP_DB_KIND="postgresql"

# Quarkus Runtime Liquibase (Named DataSource: eip)
export QUARKUS_LIQUIBASE_EIP_MIGRATE_AT_START=true
export QUARKUS_LIQUIBASE_EIP_ENABLED=true
export QUARKUS_LIQUIBASE_EIP_CHANGE_LOG="filesystem:/home/pratyush/software/eip-core-integration/eip-core-environment/demo/postgres/02_initialization/changelog/db.changelog-master.yaml"

# mTLS Metadata (Internal Platform Identity)
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStore=${EIP_CERT_DIR}/ssl-postgres/postgres-truststore.p12
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStorePassword=changeit
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_trustStoreType=PKCS12

QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_keyStore=${EIP_CERT_DIR}/ssl-postgres/client-keystore.p12
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_keyStorePassword=changeit
QUARKUS_DATASOURCE_JDBC_ADDITIONAL_JDBC_PROPERTIES_javax_net_ssl_keyStoreType=PKCS12

# Standard JAVA_OPTS for Liquibase and CLI tools
# export JAVA_OPTS="-Djavax.net.ssl.trustStore=${EIP_CERT_DIR}/ssl-postgres/postgres-truststore.p12 -Djavax.net.ssl.trustStorePassword=changeit -Djavax.net.ssl.keyStore=${EIP_CERT_DIR}/ssl-postgres/client-keystore.p12 -Djavax.net.ssl.keyStorePassword=changeit"

# Compatibility Alias for Phase 2 Initialization
export QUARKUS_DATASOURCE_JDBC_URL="${QUARKUS_DATASOURCE_EIP_JDBC_URL}"
export QUARKUS_DATASOURCE_USERNAME="${QUARKUS_DATASOURCE_EIP_USERNAME}"
export QUARKUS_DATASOURCE_PASSWORD="${QUARKUS_DATASOURCE_EIP_PASSWORD}"

# 2. Agnostic Component Registry (Explicit Property Mapping)
export export CAMEL_COMPONENT_KAMELET_LOCATION="file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets/sql,file:///home/pratyush/software/eip-core-integration/eip-core-environment/platform/kamelets"

# 3. Discovery Engine Filter
EIP_IGNORE_INFRA=ibmmq,kafka,mongodb,redis
export EIP_LIQUIBASE_ENABLED="true"

# --- CAMEL NATIVE ROUTE DISCOVERY ---
CAMEL_MAIN_ROUTES_INCLUDE_PATTERN=file:${EIP_ROUTES_DIR}/**/*.yaml
CAMEL_MAIN_DUMP_ROUTES=true

# --- PLATFORM METADATA ---
EIP_BOOTSTRAP_DISABLED=true
EIP_CONFIG_DIR=${EIP_ROUTES_DIR}
