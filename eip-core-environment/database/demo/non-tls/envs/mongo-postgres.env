# Fuel for Agnostic Database Extension
# Tenant A: MongoDB
QUARKUS_CAMEL_EXT_DB_TENANT_A_TYPE=mongo
QUARKUS_CAMEL_EXT_DB_TENANT_A_URI=mongodb://localhost:27017/eip
QUARKUS_CAMEL_EXT_DB_TENANT_A_TLS=false

# Tenant B: PostgreSQL
QUARKUS_CAMEL_EXT_DB_TENANT_B_TYPE=postgres
QUARKUS_CAMEL_EXT_DB_TENANT_B_URI=jdbc:postgresql://localhost:5432/eip
QUARKUS_CAMEL_EXT_DB_TENANT_B_USERNAME=postgres
QUARKUS_CAMEL_EXT_DB_TENANT_B_PASSWORD=postgres
QUARKUS_CAMEL_EXT_DB_TENANT_B_TLS=false

# MongoDB is strictly disabled to prevent connection errors
QUARKUS_MONGODB_HEALTH_ENABLED=false
QUARKUS_MONGODB_DEVSERVICES_ENABLED=false
QUARKUS_MONGODB_CONNECT_ON_STARTUP=false
QUARKUS_MONGODB_CONNECTION_STRING=mongodb://localhost:27017/?heartbeatFrequencyMS=2147483647&serverSelectionTimeoutMS=1
QUARKUS_LOG_CATEGORY__ORG_MONGODB_DRIVER__LEVEL=OFF
